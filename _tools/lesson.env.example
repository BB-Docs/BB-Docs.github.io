# Copy this file to _tools/lesson.env and fill in your values.
# (lesson.env is gitignored — it holds your machine-specific config.)

# Name of the rclone remote you created with `rclone config` (type: drive).
RCLONE_REMOTE="gdrive"

# ID of the "Shared with me" Drive folder that holds the lesson .md files.
# Get it from the folder's share link:
#   https://drive.google.com/drive/folders/1AbCdEfGhIjKlMnOpQrStUv  <-- this part
DRIVE_FOLDER_ID="PASTE_FOLDER_ID_HERE"

# Subfolder within that shared folder holding the lesson .md files.
# Set to "" to read the folder root instead.
DRIVE_SUBDIR="MkDocs"

# These already match your site; change only if the repo/URL changes.
REPO="BB-Docs/BB-Docs.github.io"
SITE_URL="https://bb-docs.github.io"
GIT_NAME="pradeepcb"
GIT_EMAIL="pradeepcb@gmail.com"
